class Graph:
    def __init__(self):
        self.graph = {}

    # Add edge
    def add_edge(self, u, v):
        if u not in self.graph:
            self.graph[u] = []
        if v not in self.graph:
            self.graph[v] = []
        self.graph[u].append(v)

    # Depth Limited Search (DLS)
    def dls(self, node, target, depth, visited):
        if depth < 0:
            return False

        print(node, end=" ")
        if node == target:
            return True

        visited.add(node)

        for neighbor in self.graph[node]:
            if neighbor not in visited:
                if self.dls(neighbor, target, depth - 1, visited):
                    return True

        return False

    # IDDFS
    def iddfs(self, start, target, max_depth):
        for depth in range(max_depth + 1):
            print(f"\nDepth Level {depth}: ", end="")
            visited = set()

            if self.dls(start, target, depth, visited):
                print("\nTarget found!")
                return

        print("\nTarget not found within depth limit.")


# Create graph
g = Graph()
g.add_edge('A', 'B')
g.add_edge('A', 'C')
g.add_edge('B', 'D')
g.add_edge('B', 'E')
g.add_edge('C', 'F')

# Run IDDFS
g.iddfs('A', 'F', 3)